PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/agileflow?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this
CLIENT_URL=http://localhost:5173

# Email (SMTP) — optional, notifications are skipped if not set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=AgileFlow <your_email@gmail.com>
